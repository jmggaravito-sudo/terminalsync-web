# Copy this to .env.local and fill in real values.
# NEVER commit .env.local — it's in .gitignore.

# ── Stripe ──────────────────────────────────────────────────────────────
# Use test keys (sk_test_*, whsec_*) during development.
# Swap to live keys only when deploying to production.
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# Create these two recurring products in your Stripe dashboard:
#   Pro    — $19/mo
#   Agency — $49/mo
# Then paste the price IDs (price_*) here.
STRIPE_PRICE_PRO=price_xxx_pro_monthly
STRIPE_PRICE_AGENCY=price_xxx_agency_monthly

# Public: used in browser — must be the publishable key (pk_*), NOT secret.
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx

# ── Site ────────────────────────────────────────────────────────────────
# Used to build absolute URLs (success/cancel redirects, webhooks).
# In Vercel this is set automatically via VERCEL_URL, but define it in
# .env.local for consistent local testing:
NEXT_PUBLIC_SITE_URL=http://localhost:3131

# ── Rewardful (programa de afiliados) ───────────────────────────────────
# Setup:
#   1. Crear cuenta en https://www.rewardful.com (free trial 14 días)
#   2. Settings → API Keys → copiar la "Public API Key" abajo
#   3. Settings → Stripe → conectar tu cuenta Stripe (live + test)
#   4. Affiliates → Signup Page → copiar la URL pública abajo
#
# El script de tracking se carga automáticamente cuando esta var está set.
# Si está vacía, todo el flujo de afiliados queda dormido y no se inyecta
# nada en el HTML — perfecto para entornos sin Rewardful.
NEXT_PUBLIC_REWARDFUL_API_KEY=
NEXT_PUBLIC_REWARDFUL_SIGNUP_URL=

# ── Marketplace (Stripe Connect Express) ────────────────────────────────
# Setup:
#   1. Stripe Dashboard → Connect → Get Started (Express).
#   2. Copy the Connect "client_id" (ca_*) here. Used when creating
#      account links. Server-only, no NEXT_PUBLIC_ prefix.
#   3. Enable these webhook events on your Stripe webhook endpoint
#      (in addition to the subscription events already wired):
#        - account.updated
#        - transfer.created
#        - checkout.session.completed (already enabled)
#   4. Apply the SQL migration: supabase/migrations/0001_marketplace.sql.
STRIPE_CONNECT_CLIENT_ID=ca_xxx

# Comma-separated list of admin emails (lowercase). These accounts can
# approve/reject marketplace listings via PATCH /api/marketplace/listings/[id].
# Empty = no admins, which means no listings get approved. Set this before
# launching the marketplace.
ADMIN_EMAILS=jm@terminalsync.ai

# Service-role key for server-side Supabase ops. Already required by the
# Stripe webhook; the marketplace API routes use the same admin client.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# ── Internal endpoints (n8n outreach flow) ──────────────────────────────
# Shared-secret bearer token for the /api/internal/* endpoints. The n8n
# outreach workflow sets `Authorization: Bearer <this>` when POSTing each
# DM-sent event to /api/internal/leads-sent.
#
# Generate with: openssl rand -hex 32
# Put the same value into the n8n credential vault as `TS_INTERNAL_TOKEN`.
# Apply the SQL migration: supabase/migrations/0002_outreach_leads.sql.
INTERNAL_LEADS_TOKEN=

# Slack incoming webhook for #partnerships. Used by /api/internal/leads-replied
# and /leads-converted to ping the team in real time. Setup:
#   1. https://api.slack.com/apps → Create New App → From scratch
#   2. App name: "TerminalSync Outreach", pick your workspace
#   3. Sidebar → Incoming Webhooks → toggle ON
#   4. Add New Webhook to Workspace → choose #partnerships → Allow
#   5. Copy the URL (starts with https://hooks.slack.com/services/...)
# When empty, the lead-replied / lead-converted endpoints still update the
# DB but skip the Slack ping (no error, just a console log).
SLACK_PARTNERSHIPS_WEBHOOK_URL=
